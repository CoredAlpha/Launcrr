# ============================================================
#  LAUNCRR — Environment Variables
#  Copy this to .env.local → fill in your values
# ============================================================

# ─── DATABASE ───
# Free: neon.tech / supabase.com / railway.app
DATABASE_URL="postgresql://user:pass@host:5432/launcrr?sslmode=require"

# ─── AUTH (NextAuth v5) ───
AUTH_SECRET="run: npx auth secret"
AUTH_URL="http://localhost:3000"

# ─── TWITTER/X OAUTH 2.0 (user login) ───
# Get from: developer.x.com → App → Keys & Tokens
AUTH_TWITTER_ID=""
AUTH_TWITTER_SECRET=""

# ─── SOLANA ───
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
NEXT_PUBLIC_SOLANA_NETWORK="mainnet-beta"

# ─── PUMPPORTAL ───
PUMPPORTAL_API_KEY=""

# ─── OPENAI ───
OPENAI_API_KEY=""

# ─── BOT (for later) ───
BOT_HANDLE="launcrr"
TWITTER_BOT_USERNAME=""
TWITTER_BOT_PASSWORD=""
TWITTER_BOT_EMAIL=""
